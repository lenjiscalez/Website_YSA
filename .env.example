# Notion integration token (shared by all Notion-connected features)
NOTION_API_KEY=your_notion_integration_token_here

# Notion database ID for the blog (existing)
NOTION_DATABASE_ID=your_blog_database_id_here

# Notion database ID for the hero case study carousel (new — separate DB)
NOTION_CASE_STUDIES_DB_ID=your_case_studies_database_id_here
